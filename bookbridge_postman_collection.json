							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.success && jsonData.data && jsonData.data.disputeId) {",
									"    pm.environment.set(\"disputeId\", jsonData.data.disputeId);",
