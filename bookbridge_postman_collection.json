						"body": {
							"mode": "raw",
							"raw": "{\n    \"transactionId\": {{transactionId}},\n    \"reason\": \"Incorrect Edition received\",\n    \"description\": \"The seller listed this book as 4th Edition but shipped the old 3rd Edition instead. The cover is different and chapters do not match the class syllabus.\"\n}"
